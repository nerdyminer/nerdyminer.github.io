        "            z=contour_grid.to_numpy(),\n",
        "            colorscale=\"RdYlGn\",\n",
        "            contours=dict(\n",
        "                coloring=\"heatmap\",\n",
        "                showlabels=True,\n",
        "                labelfont=dict(\n",
        "                    size=11,\n",
        "                    color=\"black\",\n",
        "                    family=PLOTLY_FONT,\n",
        "                ),\n",
        "            ),\n",
        "            line=dict(\n",
        "                color=\"black\",\n",
        "                width=1.2,\n",
        "                dash=\"dash\",\n",
        "            ),\n",
        "            connectgaps=True,\n",
        "            colorbar=dict(\n",
        "                title=dict(\n",
        "                    text=\"<b>Rendimiento (tph)</b>\",\n",
        "                    side=\"right\",\n",
        "                    font=dict(size=15, family=PLOTLY_FONT),\n",
        "                ),\n",
        "                tickfont=dict(size=12, family=PLOTLY_FONT),\n",
        "                x=1.02,\n",
        "                thickness=24,\n",
