      "source": [
        "# Llevamos a formato `datetime` las fechas de las campañas.\n",
        "reliner_data[\"init_date\"] = pd.to_datetime(reliner_data[\"init_date\"])\n",
        "reliner_data[\"end_date\"] = pd.to_datetime(reliner_data[\"end_date\"])"
