        "Z_ensemble = Z_ensemble.reshape(X1.shape)\n",
        "Z_tree = Z_tree.reshape(X1.shape)\n",
        "y_pred_train_ensemble = bagging_model.predict(X_train)\n",
        "y_pred_train_tree = tree_model.predict(X_train)\n",
