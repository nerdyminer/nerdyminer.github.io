        "ax.set_xlabel(r\"Probabilidad de acierto ($p$)\", fontsize=11, labelpad=10)\n",
        "ax.set_ylabel(r\"Probabilidad de error ($q$)\", fontsize=11, labelpad=10)\n",
        "ax.set_title(\n",
        "    \"Evolución del error de un ensamble bajo reglas de votación dura\",\n",
