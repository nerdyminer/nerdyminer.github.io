      "source": [
        "# Construimos nuestro conjunto de datos.\n",
        "X = 2 * rng.random(size=(100, 1))\n",
        "y = (1/2) - 2 * X[:, 0] + np.cos(X[:, 0]) + rng.random(size=100)"
