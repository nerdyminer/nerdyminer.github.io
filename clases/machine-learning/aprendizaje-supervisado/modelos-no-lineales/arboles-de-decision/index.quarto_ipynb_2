        ")\n",
        "ax.set_xlabel(r\"Umbrales de decisión ($\\nu'_{k}$)\", fontsize=11, labelpad=10)\n",
        "ax.set_ylabel(\"Índice de Gini\", fontsize=11, labelpad=10)\n",
