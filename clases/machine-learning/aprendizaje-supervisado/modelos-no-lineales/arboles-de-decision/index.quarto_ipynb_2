    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Instanciamos y entrenamos nuestro modelo.\n",
        "model1 = DecisionTreeClassifier(max_leaf_nodes=3, random_state=42)\n",
        "model1.fit(X_train, y_train);"
      ],
      "id": "477d9214",
