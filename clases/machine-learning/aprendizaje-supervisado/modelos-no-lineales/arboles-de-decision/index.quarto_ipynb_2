      "source": [
        "#| label: fig-regression-tree-1d\n",
        "#| fig-cap: Trazas escalonadas de árboles de regresión con distinta profundidad máxima.\n",
        "# Creamos nuestros modelos, los entrenamos, y verificamos los resultados.\n",
        "depths = [2, 5]\n",
