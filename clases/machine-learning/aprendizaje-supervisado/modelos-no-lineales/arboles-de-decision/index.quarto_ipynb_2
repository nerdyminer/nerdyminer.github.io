    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Definimos una grilla fija con valores para nuestros hiperparámetros.\n",
        "max_depths = [2, 4, 6]\n",
        "min_samples_splits = [16, 8, 2]\n",
        "min_samples_leaves = [10, 5, 1]"
