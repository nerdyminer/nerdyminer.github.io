    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Descargamos el conjunto de datos IRIS.\n",
        "iris_dataset = load_iris()"
      ],
      "id": "0f6bc8f2",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Generamos la matriz de diseño y el vector de valores observados.\n",
        "X = iris_dataset[\"data\"]\n",
        "y = iris_dataset[\"target\"]"
      ],
      "id": "46c92e96",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Separamos nuestros conjunto de datos en datos de entrenamiento y de prueba.\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, stratify=y, random_state=42)"
      ],
      "id": "67164712",
