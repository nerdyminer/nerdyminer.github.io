        "    color=\"firebrick\",\n",
        "    ax=ax[0, 0],\n",
        ")\n",
        "\n",
        "p2 = sns.boxplot(\n",
        "    data=data,\n",
        "    x=\"ROCK NAME\",\n",
        "    y=\"AL2O3(WT%)\",\n",
        "    color=\"deepskyblue\",\n",
        "    ax=ax[0, 1],\n",
        ")\n",
        "\n",
        "p3 = sns.boxplot(\n",
        "    data=data,\n",
        "    x=\"ROCK NAME\",\n",
        "    y=\"NB(PPM)\",\n",
        "    color=\"forestgreen\",\n",
        "    ax=ax[1, 0],\n",
        ")\n",
        "\n",
        "p4 = sns.boxplot(\n",
        "    data=data,\n",
        "    x=\"ROCK NAME\",\n",
        "    y=\"YB(PPM)\",\n",
        "    color=\"indigo\",\n",
        "    ax=ax[1, 1],\n",
        ")\n",
        "\n",
        "p5 = sns.boxplot(\n",
        "    data=data,\n",
        "    x=\"ROCK NAME\",\n",
        "    y=\"TH(PPM)\",\n",
        "    color=\"orange\",\n",
        "    ax=ax[2, 0],\n",
        ")\n",
        "\n",
        "p6 = sns.boxplot(\n",
        "    data=data,\n",
        "    x=\"ROCK NAME\",\n",
        "    y=\"ZR(PPM)\",\n",
        "    color=\"navy\",\n",
        "    ax=ax[2, 1],\n",
        ")\n",
        "\n",
        "fig.suptitle(\n",
        "    \"Distribuciones observadas de puntos por clase (sin outliers)\",\n",
        "    fontsize=14,\n",
        "    fontweight=\"bold\",\n",
        ")\n",
        "\n",
        "plt.tight_layout()"
      ],
      "id": "fig-modelos-de-clasificacion-parte-ii-17",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Y ahora sí que las distribuciones se observan claramente. Notemos además que hay tendencias claras de cada una de estas columnas con respecto a cada tipo muestra de roca, lo que debemos ser capaces de capturar por medio de nuestro modelo.\n",
        "\n",
        "Sólo como *doble-check*, vamos a generar ahora una eliminación de *outliers* más general, donde simplemente trabajaremos con todos los puntos, por variable independiente, que se encuentren en el rango definido por los percentiles 5% y 95%., a fin de evitar destruir correlaciones por efecto de valores infrecuentes demasiado alejados de la media de cada elemento y/o compuesto químico:"
      ],
      "id": "f6c0f510"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Definimos las variables independientes y la variable de \n",
        "# respuesta de este dataset.\n",
        "target = \"ROCK NAME\"\n",
        "feats = [col_k for col_k in data.columns if col_k != target]\n",
        "\n",
        "# Definimos los percentiles.\n",
        "INF_B = 0.05\n",
        "SUP_B = 0.95\n",
        "\n",
        "# Obtenemos los valores en cada caso.\n",
        "q_min = data[feats].quantile(INF_B)\n",
        "q_max = data[feats].quantile(SUP_B)\n",
        "\n",
        "# Y luego obtenemos la amplitud de este rango completo.\n",
        "interval = q_max - q_min\n",
        "\n",
        "# Finalmente, removemos los outliers.\n",
        "data = data[\n",
        "    ~(\n",
        "        (data[feats] < (q_min - interval)) |(data[feats] > (q_max + interval))\n",
        "    )\n",
        "    .any(axis=1)\n",
        "]"
      ],
      "id": "f9b70983",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Y ya tenemos un dataset sin valores extremos. Ahora procedemos a codificar nuestra variable de salida mediante una estrategia de tipo ordinal. Tal estrategia tiene sentido, porque cada tipo de roca puede ordenarse en una serie creciente donde, mientras más contenido de minerales de tipo feldespato existan en cada una, más alcalina será la roca a la que representa la muestra (en el orden *\"basalto, andesita, dacita, riolita\"*):"
      ],
      "id": "1bf53294"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "from sklearn.preprocessing import OrdinalEncoder"
      ],
      "id": "ab1f3059",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Codificamos los valores de la variable de salida.\n",
        "encoder = OrdinalEncoder()\n",
        "target_encoded = encoder.fit_transform(\n",
        "    data[\"ROCK NAME\"].to_numpy().reshape(-1, 1)\n",
        ")"
      ],
      "id": "7cabba6f",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Las categorías son las siguientes:"
      ],
      "id": "62d7000e"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Mostramos las categorías obtenidas por el codificador.\n",
        "encoder.categories_"
      ],
      "id": "c39f7608",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "¡Justo como queríamos!\n",
        "\n",
        "Vamos a evaluar igualmente las matrices de correlación resultantes ahora que hemos codificado nuestra variable de salida en términos ordinales:"
      ],
      "id": "219558d3"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Construimos la matriz de correlación.\n",
        "corr_matrix = pd.DataFrame(\n",
        "    np.hstack([data[feats], target_encoded]),\n",
        "    columns=data.columns.tolist()[1:] + [\"tipo_roca_codif\"]\n",
        ").corr()"
      ],
      "id": "0e79620e",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Y visualizamos esta matriz de correlación por medio de un mapa de calor:"
      ],
      "id": "4e3a6226"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-modelos-de-clasificacion-parte-ii-18\n",
        "#| fig-cap: Matriz de correlación Conjunto de datos completo (no normalizado).\n",
        "fig, ax = plt.subplots(figsize=(9, 6))\n",
        "sns.heatmap(\n",
        "    corr_matrix,\n",
        "    annot=True,\n",
        "    fmt=\".2f\",\n",
        "    ax=ax,\n",
        "    cmap=\"RdGy_r\",\n",
        "    cbar=True,\n",
        "    cbar_kws={\"label\" : \"Coef. correlación de Pearson\"},\n",
        "    vmin=-1,\n",
        "    vmax=1,\n",
        ")\n",
        "\n",
        "ax.set_title(\n",
        "    \"Matriz de correlación\\nConjunto de datos completo (no normalizado)\",\n",
        "    fontsize=14,\n",
        "    fontweight=\"bold\",\n",
        "    pad=10,\n",
        ")\n",
        "\n",
        "plt.tight_layout()"
      ],
      "id": "fig-modelos-de-clasificacion-parte-ii-18",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Al observar la matriz de correlación por medio de este mapa de calor, notamos que: \n",
        "\n",
        "- La columna `AU(PPB)` presenta una muy baja correlación (en magnitud) con respecto a todas las demás variables de nuestro conjunto de datos.\n",
        "- Existen varias variables que se encuentra altamente correlacionadas entre sí. Los casos más extremos son los pares `(Y(PPM), YB(PPM))` (con `0.93` de correlación) y `(CE(PPM), LA(PPM))` (con `0.96` de correlación). Imputar variables altamente correlacionadas entre sí a un modelo (cualquiera sea éste) no es bueno, porque tales variables tienden a ser redundantes las unas con las otras y, por tanto, aumentamos la complejidad de los modelos resultantes (por la mayor dimensión del espacio de entrada) a cambio de poca o nula información valiosa adicional. Por lo tanto, estas correlaciones cruzadas son un indicador de que debemos seleccionar determinadas variables (en desmedro de otras) previo a construir los conjuntos de entrenamiento y de prueba para nuestro modelo.\n",
        "\n",
        "Por el momento, la elección más sensata es eliminar a priori la columna `AU(PPB)`, debido a que si únicamente nos quedamos con aquellas filas para las cuales dicha columna contiene datos, corremos el riesgo de perder representatividad en las clases menos frecuentes, ya que el dataset de por sí está muy desbalanceado hacia las rocas ferromagnesianas (basalto y andesita). Por otro lado, también eliminaremos variables que tengan alguna correlación por encima (en magnitud) de un determinado umbral. Para ello, generamos un procedimiento muy sencillo como sigue:"
      ],
      "id": "9ec1b87e"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Eliminamos la columna `AU(PPB)`.\n",
        "data.drop(\"AU(PPB)\", axis=1, inplace=True)\n",
        "\n",
        "# Definimos una lista con correlaciones progresivamente más grandes.\n",
        "corr_vals = np.linspace(start=0.1, stop=1.0, num=5).tolist()\n",
        "\n",
        "# Construimos nuevamente una matriz de correlación, pero ahora \n",
        "# simplemente considerando los valores absolutos de cada una.\n",
        "feats = [feat_k for feat_k in feats if feat_k != \"AU(PPB)\"]\n",
        "abs_corr_matrix = pd.DataFrame(\n",
        "    np.hstack([data[feats], target_encoded]),\n",
        "    columns=data.columns.tolist()[1:] + [\"tipo_roca_codif\"]\n",
        ").corr().abs()\n",
        "\n",
        "# Debido a que la matriz de correlación es simétrica, nos quedamos\n",
        "# con su submatriz triangular superior.\n",
        "upper = abs_corr_matrix.where(\n",
        "    np.triu(np.ones(abs_corr_matrix.shape), k=1).astype(bool)\n",
        ")\n",
        "\n",
        "# Y construimos un loop sencillo para obtener las posibles variables\n",
        "# a descartar suponiendo que se supere un determinado umbral de correlación.\n",
        "dropped_feats = []\n",
        "for corr_j in corr_vals:\n",
        "    to_drop_j = len([col_k for col_k in upper.columns if any(upper[col_k] > corr_j)])\n",
        "    dropped_feats.append(to_drop_j)"
      ],
      "id": "69d5cb7d",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Y ahora visualizamos el resultado de este procedimiento:"
      ],
      "id": "9c816c1e"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-modelos-de-clasificacion-parte-ii-19\n",
        "#| fig-cap: Número de variables eliminadas conforme el umbral de correlación.\n",
        "# Visualizamos nuestros resultados.\n",
        "# Graficamos nuestros resultados.\n",
        "fig, ax = plt.subplots(figsize=(9, 5))\n",
        "ax.plot(corr_vals, dropped_feats, \"ro-\")\n",
        "ax.set_xlabel(\"Coeficiente de correlación\", fontsize=12, labelpad=10)\n",
        "ax.set_ylabel(\"Número de variables eliminadas\", fontsize=12, labelpad=10)\n",
        "ax.set_title(\n",
        "    \"Número de variables eliminadas conforme el umbral de correlación\",\n",
        "    fontsize=14,\n",
        "    fontweight=\"bold\",\n",
        "    pad=10,\n",
        ")\n",
        "\n",
        "plt.tight_layout()"
      ],
      "id": "fig-modelos-de-clasificacion-parte-ii-19",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Conforme el gráfico anterior, podemos observar que, si ponemos como límite una correlación cruzada de `0.8`, eliminaremos un total de 5 variables aproximadamente. De ser ese el caso, eliminaríamos la mitad de las variables del conjunto de datos. Por otro lado, si limitamos las correlaciones cruzadas a `0.9`, eliminaremos un total de dos variables por este método. Por lo tanto, a fin de evitar redundancias, setearemos el límite en `0.85` y eliminaremos las variables que presenten correlaciones cruzadas iguales o mayores que ese valor:"
      ],
      "id": "13643f1f"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Definimos las columnas a eliminar.\n",
        "CORR_TOL = 0.85\n",
        "to_drop = [\n",
        "    col_k for col_k in upper.columns if any(upper[col_k] > CORR_TOL)\n",
        "]\n",
        "\n",
        "# Mostramos dichas columnas.\n",
        "print(f\"Columnas a eliminar:\\n{to_drop}\")\n",
        "\n",
        "# Y eliminamos estas columnas.\n",
        "data.drop(to_drop, axis=1, inplace=True)"
      ],
      "id": "f69a8159",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Ahora concatenaremos todo, a fin de disponer de un DataFrame listo para el consumo:"
      ],
      "id": "eaa6789c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Concatenamos todo en un único DataFrame.\n",
        "df = pd.concat(\n",
        "    [\n",
        "        data.iloc[:, 1:], \n",
        "        pd.Series(\n",
        "            data=target_encoded.reshape(-1), \n",
        "            index=data.index,name=\"rock_code\"\n",
        "        ),\n",
        "    ],\n",
        "    axis=1,\n",
        ")"
      ],
      "id": "320306fb",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Procedemos ahora a separar nuestro conjunto de datos. Para ello, realizaremos un muestreo estratificado, a fin de mantener la proporción relativa de las clases en los subconjuntos resultantes:"
      ],
      "id": "bea7e642"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Definimos algunos parámetros relevantes a utilizar.\n",
        "SEED = 42\n",
        "PROP = 0.2\n",
        "\n",
        "# Y generamos nuestro muestreo.\n",
        "train_set, test_set = train_test_split(\n",
        "    df, test_size=PROP, stratify=df[\"rock_code\"], random_state=SEED,\n",
        ")\n",
        "\n",
        "# Chequeamos las proporciones de las clases en ambos subconjuntos de datos.\n",
        "print(\n",
        "    \"Frecuencia relativa de las clases en el conjunto de entramiento\\n\",\n",
        "    train_set[\"rock_code\"].value_counts(normalize=True)\n",
        ")\n",
        "print(\n",
        "    \"\\nFrecuencia relativa de las clases en el conjunto de prueba\\n\",\n",
        "    test_set[\"rock_code\"].value_counts(normalize=True)\n",
        ")"
      ],
      "id": "4cdd621d",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Las frecuencias relativas de cada clase en los conjuntos de entrenamiento y de prueba son prácticamente las mismas. Ahora construimos los correspondientes pares `(X, y)` para cada uno, considerando la eliminación de las filas con registros vacíos en cada caso:"
      ],
      "id": "dac64d92"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Generación de los pares (X, y) para los conjuntos de entrenamiento y de prueba.\n",
        "X_train, X_test = train_set.dropna().iloc[:, :-1].values, test_set.dropna().iloc[:, :-1].values\n",
        "y_train, y_test = train_set.dropna().iloc[:, -1].values, test_set.dropna().iloc[:, -1].values"
      ],
      "id": "df2f8b8e",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Ahora procederemos a construir nuestro modelo. Para ello, generaremos un objeto de tipo `Pipeline` que considerará, además, el escalamiento de nuestro conjunto de datos, a fin de que todos ellos tengan el mismo orden de magnitud. Para considerar el efecto del desbalance en términos de la frecuencia de las clases en la variable de respuesta, seteamos el parámetro `class_weight=\"balanced\"` en nuestro modelo:"
      ],
      "id": "202d3c66"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Construimos nuestra Pipeline.\n",
        "model = Pipeline(\n",
        "    steps=[\n",
        "        (\n",
        "            \"scaler\", \n",
        "            StandardScaler()\n",
        "        ), \n",
        "        (\n",
        "            \"estimator\", \n",
        "            LogisticRegression(\n",
        "                penalty=\"elasticnet\",\n",
        "                solver=\"saga\", \n",
        "                class_weight=\"balanced\",    \n",
        "            ),\n",
        "        ),\n",
        "    ],\n",
        ")"
      ],
      "id": "b44ecd72",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Usando el objeto anterior como base, generaremos una búsqueda aleatorizada de hiperparámetros a fin de determinar la mejor combinación de los mismos para el modelo resultante:"
      ],
      "id": "1b08005b"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Generamos una búsqueda aleatorizada de mejores hiperparámetros \n",
        "# para nuestro modelo, siguiendo además un procedimiento de\n",
        "# validación cruzada con 3 subconjuntos.\n",
        "param_distributions = {\n",
        "    \"estimator__l1_ratio\": np.linspace(start=0, stop=1, num=20),\n",
        "    \"estimator__C\": np.linspace(start=0.01, stop=1, num=20),\n",
        "}\n",
        "\n",
        "searcher = RandomizedSearchCV(\n",
        "    estimator=model,\n",
        "    param_distributions=param_distributions,\n",
        "    scoring=[\"roc_auc_ovr_weighted\", \"f1_macro\"],\n",
        "    refit=\"f1_macro\",\n",
        "    n_jobs=-1,\n",
        "    cv=3,\n",
        "    verbose=0,\n",
        "    random_state=42,\n",
        ")\n",
        "\n",
        "searcher.fit(X_train, y_train)"
      ],
      "id": "48885a95",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "La mejor combinación de hiperparámetros encontrada es la siguiente:"
      ],
      "id": "b0c771e3"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Mostramos en pantalla el resultado de la búsqueda de hiperparámetros.\n",
        "searcher.best_params_"
      ],
      "id": "dc6176b1",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Y, por tanto, llevamos el mejor modelo encontrado a una variable para luego trabajar con él:"
      ],
      "id": "1552a10f"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Obtenemos el mejor modelo encontrado.\n",
        "best_model = searcher.best_estimator_"
      ],
      "id": "a899a567",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "A continuación revisaremos las métricas de desempeño para este modelo. Concretamente, presentaremos la matriz de confusión, el puntaje F1 macro-ponderado (dado que las clases no se encuentran balanceadas) y el área bajo la curva ROC macro-ponderada conforme una estrategia de tipo OvR. Las últimas dos métricas nos permitirán evaluar la capacidad del modelo para discriminar entre los distintos tipos posibles de rocas conforme la información de entrada.\n",
        "\n",
        "Partimos pues generando las correspondientes predicciones para los conjuntos de entrenamiento y de prueba:"
      ],
      "id": "b5245c19"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Clases predichas por nuestro modelo.\n",
        "y_train_pred = best_model.predict(X_train)\n",
        "y_test_pred = best_model.predict(X_test)"
      ],
      "id": "51fd4993",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Y luego calculamos las correspondientes matrices de confusión:"
      ],
      "id": "f7c66d3e"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Matrices de confusión para ambos casos.\n",
        "cm_train = confusion_matrix(y_true=y_train, y_pred=y_train_pred)\n",
        "cm_test = confusion_matrix(y_true=y_test, y_pred=y_test_pred)"
      ],
      "id": "2144a773",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "A continuación, generamos las correspondientes visualizaciones para estas matrices por medio de mapas de calor:"
      ],
      "id": "f6e9408a"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Generamos una lista con las categorías asociadas a cada clase.\n",
        "rock_classes = encoder.categories_[0].tolist()\n",
        "\n",
        "# Pasamos las matrices de confusión a un formato de DataFrame.\n",
        "cm_train_df = pd.DataFrame(data=cm_train, index=rock_classes, columns=rock_classes)\n",
        "cm_test_df  = pd.DataFrame(data=cm_test, index=rock_classes, columns=rock_classes)"
      ],
      "id": "61ad5909",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-modelos-de-clasificacion-parte-ii-20\n",
        "#| fig-cap: Matriz de confusión Conjunto de entrenamiento.\n",
        "# Y visualizamos ambas en un mapa de calor.\n",
        "fig, ax = plt.subplots(figsize=(9, 10), nrows=2, sharex=True)\n",
        "p1 = sns.heatmap(\n",
        "    cm_train_df, \n",
        "    annot=True, \n",
        "    fmt=\".0f\", \n",
        "    ax=ax[0], \n",
        "    cmap=\"RdGy_r\", \n",
