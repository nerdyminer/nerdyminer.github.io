      "id": "0a9c6cc2",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Las clases almacenadas en el modelo coinciden con las posiciones de cada elemento en el vector\n",
        "# con los puntajes de decisión.\n",
        "model.classes_"
