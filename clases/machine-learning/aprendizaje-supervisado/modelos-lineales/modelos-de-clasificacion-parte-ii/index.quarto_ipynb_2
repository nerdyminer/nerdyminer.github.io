    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Seleccionamos una imagen al azar del conjunto de entrenamiento.\n",
        "rng = np.random.default_rng(seed=42)\n",
        "idx = rng.choice(X_train.shape[0], 1)\n",
        "image = X_train[idx]\n",
        "\n",
        "# Y verificamos el número al que ésta representa.\n",
