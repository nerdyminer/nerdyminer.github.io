        "---\n",
        "title: \"Modelos de clasificación - Parte II\"\n",
        "subtitle: \"Regresión logística binaria, clasificación multinomial y casos de estudio aplicados\"\n",
        "section_href: \"/clases/machine-learning/aprendizaje-supervisado/modelos-lineales/\"\n",
        "toc: true\n",
