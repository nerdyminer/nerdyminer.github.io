        "from sklearn.base import BaseEstimator, ClassifierMixin\n",
        "from sklearn.utils import check_random_state\n",
        "from sklearn.utils.validation import (\n",
        "    check_array,\n",
        "    check_is_fitted,\n",
        "    check_X_y,\n",
        ")"
