        "title: \"Máquinas de soporte vectorial\"\n",
        "subtitle: \"Introduciendo márgenes, kernels y programación cuadrática\"\n",
        "section_href: \"/clases/machine-learning/aprendizaje-supervisado/modelos-lineales/\"\n",
        "toc: true\n",
        "toc-depth: 3\n",
