      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Inicializamos diccionarios para almacenar predicciones.\n",
        "y_pred = {}\n",
        "y_pred_test = {}\n",
