        "ax[0].set_title(\"Caso lineal\", fontsize=14, fontweight=\"bold\", pad=10)\n",
        "ax[1].set_title(\"Caso polinómico\", fontsize=14, fontweight=\"bold\", pad=10)\n",
        "ax[0].grid(True)\n",
        "ax[1].grid(True)\n",
        "plt.tight_layout()"
      ],
      "id": "fig-modelos-lineales-regularizados-bayesianos-y-generalizados-01",
