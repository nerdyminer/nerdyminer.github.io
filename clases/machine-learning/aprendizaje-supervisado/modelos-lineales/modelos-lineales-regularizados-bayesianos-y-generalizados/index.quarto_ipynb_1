        "#| label: fig-modelos-lineales-regularizados-bayesianos-y-generalizados-02\n",
        "#| fig-cap: Coeficientes estimados por regresión.\n",
        "# Visualizamos los resultados\n",
        "fig, ax = plt.subplots(ncols=2, figsize=(9, 5))\n",
