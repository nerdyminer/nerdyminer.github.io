        "        y_pred = model_j.predict(df_i)\n",
        "\n",
        "        # Graficamos los resultados del correspondiente modelo.\n",
        "        pd.Series(y_pred).plot(\n",
        "            kind=\"hist\", bins=np.linspace(start=-1, stop=4, num=30), color=\"teal\",\n",
        "            ax=ax[row_i, col_j + 1], ec=\"k\", lw=0.5,\n",
