        "        # supuesto, sean compatibles).\n",
        "        X = np.asarray(X, dtype=float)\n",
        "        y = np.asarray(y, dtype=float).ravel()\n",
        "\n",
        "        # Determinamos la dimensión de la matriz de diseño.\n",
        "        m, n = X.shape\n",
        "\n",
        "        # Estandarizamos los valores de X, ya que el modelo LASSO es sensible a\n",
        "        # la escala de sus valores.\n",
        "        X_mean = np.mean(X, axis=0)\n",
        "        X_std = np.std(X, axis=0, ddof=0)\n",
        "        # Evitamos división por cero en variables constantes.\n",
