      "source": [
        "#| label: fig-modelos-lineales-regularizados-bayesianos-y-generalizados-01\n",
        "#| fig-cap: Caso lineal.\n",
        "# Generamos nuestros gráficos\n",
        "fig, ax = plt.subplots(figsize=(9, 6), ncols=2)\n",
        "plot_ridge_model(\n",
