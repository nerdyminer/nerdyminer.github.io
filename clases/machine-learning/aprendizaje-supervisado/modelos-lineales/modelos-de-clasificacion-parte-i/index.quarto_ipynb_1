    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Generamos un DataFrame con todos los datos.\n",
        "data = pd.concat([mnist_data[\"data\"].copy(), y], axis=1)\n",
        "\n",
        "# Construimos los conjuntos de entrenamiento y de prueba por medio de un muestreo aleatorizado.\n",
