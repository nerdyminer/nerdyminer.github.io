        "print(\n",
        "    \"Proporción de dígitos iguales a 7 en el conjunto de entrenamiento = \"\n",
        "    +f\"{round(100 * train_set['class'].value_counts() / train_set.shape[0], 2).iloc[1]} %\"\n",
        ")\n",
        "print(\n",
        "    \"Proporción de dígitos iguales a 7 en el conjunto de prueba = \"\n",
