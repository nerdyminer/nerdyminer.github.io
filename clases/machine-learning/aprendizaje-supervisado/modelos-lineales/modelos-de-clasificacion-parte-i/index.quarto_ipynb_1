        "#| label: fig-modelos-de-clasificacion-parte-i-06\n",
        "#| fig-cap: Frontera de decisión de nuestro modelo.\n",
        "# Graficamos los resultados del modelo.\n",
        "fig, ax = plt.subplots(figsize=(9, 6))\n",
