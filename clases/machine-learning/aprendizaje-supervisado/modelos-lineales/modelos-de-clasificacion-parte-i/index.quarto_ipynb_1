        "ax.set_ylabel(r\"$y$\", fontsize=14, labelpad=15, rotation=0)\n",
        "ax.set_title(\n",
        "    r\"Donde se encuentran los valores de $x_{1}$ con respecto a las clases\",\n",
        "    pad=10,\n",
