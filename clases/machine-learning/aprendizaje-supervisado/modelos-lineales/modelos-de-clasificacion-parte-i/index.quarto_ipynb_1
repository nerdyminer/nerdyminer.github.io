    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "print(f\"Sensibilidad necesaria para una precisión del 95.0 % = {recall_w_95_prec:.2f}\")\n",
        "print(f\"Umbral de discriminación para una precisión del 95.0 % = {thresh_w_95_prec:.2f}\")"
