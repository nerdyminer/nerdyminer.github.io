        "---\n",
        "title: \"Una introducción a Scikit-Learn\"\n",
        "subtitle: \"Datos, estimadores, validación, selección de modelos y preprocesamiento\"\n",
        "section_href: \"/clases/machine-learning/aprendizaje-supervisado/modelos-lineales/\"\n",
        "toc: true\n",
        "toc-depth: 3\n",
        "page-layout: article\n",
