      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Calculamos la media, mediana y moda de la serie `feed_tpd_s1`.\n",
        "print(f\"Media anual de tonelaje procesado por la fuente 1: {feed_tpd_s1.mean():.2f} tpd\")\n",
