    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-optimizacion-aplicada-al-aprendizaje-automatico-10\n",
        "#| fig-cap: Datos simulados desde un paraboloide hiperbólico.\n",
