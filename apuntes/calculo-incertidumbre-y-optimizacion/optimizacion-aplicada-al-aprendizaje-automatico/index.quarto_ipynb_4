        "\n",
        "# Matriz Q del término cuadrático.\n",
        "# Penalizamos w1 y w2, pero no penalizamos el sesgo b.\n",
        "Q_margin = np.diag([1.0, 1.0, 0.0])\n",
        "\n",
        "# Restricciones:\n",
        "A_margin = -y_margin.reshape(-1, 1) * X_ext_margin\n",
        "c_margin = -np.ones(m_margin)"
