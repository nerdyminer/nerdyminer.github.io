        ")\n",
        "ax[1].set_xlabel(r\"$x$\", fontsize=12)\n",
        "ax[1].set_ylabel(r\"$y$\", fontsize=12)\n",
        "ax[1].set_aspect(\"equal\")\n",
        "\n",
