    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "A continuación, establecemos las penalizaciones que aplicaremos a la función objetivo:"
      ],
      "id": "dc7db2f0"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Penalización por subutilización de cargadores.\n",
        "LAMBDA_IDLE = 1.0e5\n",
        "\n",
        "# Penalización por violar disponibilidad total de camiones.\n",
        "MU_TRUCKS = 2.0e6\n",
        "\n",
        "# Calculamos el número de destinos posibles.\n",
        "n_units = len(all_units)\n",
        "n_waste = len(waste_units)"
