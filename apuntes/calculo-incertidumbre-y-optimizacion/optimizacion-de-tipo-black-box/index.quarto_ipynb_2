      "metadata": {},
      "source": [
        "# Evaluación de la función objetivo.\n",
        "for ind in pop_denorm:\n",
        "    print(ind, fobj(ind))"
      ],
      "id": "395516f4",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Y nos quedamos con el punto que genera el menor valor de todos estos agentes:"
      ],
      "id": "2d1757d8"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Obtenemos el valor mínimo de todos los evaluados.\n",
        "fitness = np.asarray([fobj(ind) for ind in pop_denorm])\n",
        "best_idx = np.argmin(fitness)\n",
        "best = pop_denorm[best_idx]\n",
        "\n",
        "# Mostramos el mejor de estos agentes en pantalla.\n",
        "best"
