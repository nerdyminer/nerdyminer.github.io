        "def initialize_population(pop_size, n, rng):\n",
        "    \"\"\"\n",
        "    Genera una población inicial aleatoria de permutaciones.\n",
        "    \"\"\"\n",
        "    population = []\n",
        "    base = np.arange(n)\n",
        "\n",
        "    for _ in range(pop_size):\n",
        "        individual = rng.permutation(base)\n",
        "        population.append(individual)\n",
        "    \n",
        "    return population"
