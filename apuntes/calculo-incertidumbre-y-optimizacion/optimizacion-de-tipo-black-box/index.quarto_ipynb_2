    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Parámetros gráficos generales.\n",
        "plt.rcParams[\"figure.dpi\"] = 90\n",
        "sns.set_theme()\n",
        "plt.style.use(\"bmh\")"
      ],
      "id": "46d0f8a1",
