    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Defininos la estructura topológica completa del enjambre.\n",
        "my_topology = Star() # La clase que define la topología del enjambre.\n",
        "my_options = {'c1': 0.6, 'c2': 0.3, 'w': 0.8} # Hiperparámetros del enjambre (arbitrarios en este ejemplo).\n",
        "my_swarm = P.create_swarm(n_particles=50, dimensions=2, options=my_options) # Instancia del enjambre."
