      "source": [
        "# Creamos una versión parametrizada de la función de Rosenbrock.\n",
        "def rosenbrock_with_args(x, a, b, c=0):\n",
        "    f = (a - x[:, 0]) ** 2 + b * (x[:, 1] - x[:, 0] ** 2) ** 2 + c\n",
        "    return f"
