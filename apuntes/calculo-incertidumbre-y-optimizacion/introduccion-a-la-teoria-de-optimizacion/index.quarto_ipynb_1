      "source": [
        "# Definimos la función de Ackley para un vector (x, y).\n",
        "def ackley(x, y):\n",
        "    return -20.0*np.exp(\n",
        "        -0.2*np.sqrt(0.5*(x**2 + y**2))\n",
        "    ) - np.exp(\n",
        "        0.5*(np.cos(2*np.pi*x) + np.cos(2*np.pi*y))\n",
        "    ) + np.e + 20"
      ],
