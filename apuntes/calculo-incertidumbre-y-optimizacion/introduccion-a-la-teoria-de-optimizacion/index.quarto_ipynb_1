    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Definimos una función que implementa el algoritmo BGD para nuestro caso particular.\n",
        "def batch_gradient_descent(Xb, Y, theta0, gamma=0.02, n_iter=3000):\n",
        "    m = Xb.shape[0] # Número total de observaciones en el lote.\n",
        "    Y = Y.reshape(-1, 1) # Adecuamos Y en un arreglo bidimensional.\n",
        "    theta_path = [] # Una lista vacía donde almacenaremos la trayectoria del algoritmo.\n",
        "    theta = theta0.copy() # Copiamos la solución inicial.\n",
        "    for iter_k in range(n_iter):\n",
        "        gradient = (2/m) * Xb.T @ (Xb @ theta - Y)\n",
        "        theta = theta - gamma * gradient\n",
        "        theta_path.append(theta)\n",
        "    return theta, theta_path"
