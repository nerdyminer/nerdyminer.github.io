      "source": [
        "# Definimos la función que controlará el programa de aprendizaje del algoritmo.\n",
        "def learning_schedule(t, t0=5, t1=50):\n",
        "    return t0 / (t + t1)"
      ],
      "id": "709fad00",
      "execution_count": null,
      "outputs": []
