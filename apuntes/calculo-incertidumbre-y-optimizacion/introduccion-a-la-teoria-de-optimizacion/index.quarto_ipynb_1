      "source": [
        "# Primeras líneas del algoritmo.\n",
        "popsize = 10\n",
        "dimensions = 4\n",
        "pop = np.random.rand(popsize, dimensions)"
      ],
      "id": "15aab7e3",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# La población inicial de agentes (10 en total).\n",
        "pop"
      ],
      "id": "16c1027e",
