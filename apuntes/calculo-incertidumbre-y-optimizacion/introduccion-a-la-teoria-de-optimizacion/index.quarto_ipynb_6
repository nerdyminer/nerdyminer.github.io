      "source": [
        "#| label: fig-introduccion-a-la-teoria-de-optimizacion-02\n",
        "#| fig-cap: Superficie $f(x,y)=x^{2}+y^{2}$ (paraboloide circular).\n",
        "# Y construimos el gráfico de la superficie.\n",
        "fig = plt.figure(figsize=(10, 6))\n",
        "ax = plt.axes(projection='3d')\n",
