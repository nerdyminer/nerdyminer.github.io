    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Evaluamos la función objetivo en cada punto crítico.\n",
        "critical_values = []\n",
        "for sol in result:\n",
        "    f_val = sym.simplify(sol[x] + sol[y])\n",
        "    critical_values.append((sol[x], sol[y], sol[lam], f_val))\n",
        "\n",
        "# Mostramos en pantalla estos puntos.\n",
