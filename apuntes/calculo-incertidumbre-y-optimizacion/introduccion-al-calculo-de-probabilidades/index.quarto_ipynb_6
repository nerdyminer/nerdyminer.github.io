      "source": [
        "Y definimos la función $U$ de manera sencilla como sigue:"
      ],
      "id": "e64583a4"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Definición de la función de distribución uniforme.\n",
        "def U(t):\n",
        "    Y = np.zeros(t.shape)\n",
        "    \n",
        "    for j in range(len(t)):\n",
        "        if t[j] < 1 and t[j] >= 0:\n",
        "            Y[j] = t[j]\n",
        "        elif t[j] < 0:\n",
        "            Y[j] = 0\n",
        "        else:\n",
        "            Y[j] = 1\n",
        "    \n",
        "    return Y"
      ],
