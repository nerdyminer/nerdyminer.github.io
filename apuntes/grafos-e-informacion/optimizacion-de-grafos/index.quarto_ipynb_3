        "# Mostramos estos resultados en pantalla.\n",
        "print(\"Gradiente respecto de w:\")\n",
        "print(grad_w)\n",
        "\n",
        "print(\"\\nGradiente respecto de b:\")\n",
        "print(grad_b)\n",
        "\n",
        "print(\"\\nGradiente respecto de x:\")\n",
        "print(grad_x)"
