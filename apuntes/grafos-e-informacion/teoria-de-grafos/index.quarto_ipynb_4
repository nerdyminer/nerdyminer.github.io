    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Y también podemos observar cómo converge la iteración de potencias hacia una **distribución de estado estable**:"
      ],
      "id": "c68c2859"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-teoria-de-grafos-13\n",
        "#| fig-cap: Convergencia iterativa del vector `PageRank`.\n",
        "# Visualización de la transición hacia un estado estable.\n",
        "fig, ax = plt.subplots(figsize=(9, 5))\n",
        "\n",
        "for j, node in enumerate(V_pr):\n",
        "    ax.plot(\n",
        "        pagerank_trajectory[:, j],\n",
        "        linewidth=2,\n",
        "        color=plt.cm.cool(j / len(V_pr)),\n",
        "        label=page_names[node]\n",
