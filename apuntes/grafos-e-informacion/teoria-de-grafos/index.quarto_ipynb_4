      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Nodos del grafo dirigido reducible.\n",
        "V_dir_red = np.arange(1, 9)\n",
        "\n",
        "# Arcos dirigidos.\n",
        "# Componentes:\n",
        "# C1 = {1, 2}, C2 = {3, 4}, C3 = {5, 6}, C4 = {7, 8}\n",
