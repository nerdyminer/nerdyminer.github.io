        "\n",
        "    ax.text(\n",
        "        x_node,\n",
        "        y_node,\n",
        "        str(node),\n",
        "        ha=\"center\",\n",
        "        va=\"center\",\n",
        "        fontsize=13,\n",
        "        fontweight=\"bold\",\n",
        "        zorder=4\n",
