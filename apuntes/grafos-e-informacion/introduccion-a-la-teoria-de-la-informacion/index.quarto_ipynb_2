        "def normal_pdf(x, mu, sigma):\n",
        "    \"\"\"\n",
        "    Densidad de una distribución normal unidimensional.\n",
        "    \"\"\"\n",
        "    return (1 / (np.sqrt(2 * np.pi) * sigma)) * np.exp(\n",
        "        -0.5 * ((x - mu) / sigma)**2\n",
        "    )\n",
        "\n",
        "\n",
        "def kl_normal_1d(mu0, sigma0, mu1, sigma1):\n",
        "    \"\"\"\n",
        "    Calcula D_KL(N(mu0, sigma0^2) || N(mu1, sigma1^2)).\n",
        "    \"\"\"\n",
        "    return (\n",
        "        np.log(sigma1 / sigma0)\n",
        "        + (sigma0**2 + (mu0 - mu1)**2) / (2 * sigma1**2)\n",
        "        - 0.5\n",
        "    )"
