    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Algunas funciones auxiliares para resolver nuestro ejercicio.\n",
        "def tokenize(sentence):\n",
        "    \"\"\"\n",
        "    Tokenizador simple para frases en minúscula.\n",
        "    \"\"\"\n",
        "    sentence = sentence.lower()\n",
        "    return re.findall(r\"[a-záéíóúñ]+\", sentence)\n",
        "\n",
        "\n",
        "def build_vocabulary(sentences):\n",
        "    \"\"\"\n",
        "    Construye vocabulario ordenado desde un conjunto de frases.\n",
        "    \"\"\"\n",
        "    vocab = sorted(set(token for s in sentences for token in tokenize(s)))\n",
        "    return np.array(vocab)\n",
        "\n",
        "\n",
        "def next_tokens_after_prefix(sentences, prefix):\n",
        "    \"\"\"\n",
        "    Extrae los tokens que aparecen inmediatamente después de un prefijo.\n",
        "    \"\"\"\n",
        "    prefix = tuple(prefix)\n",
        "    k = len(prefix)\n",
        "    next_tokens = []\n",
        "\n",
        "    for sentence in sentences:\n",
        "        tokens = tokenize(sentence)\n",
        "\n",
        "        for i in range(len(tokens) - k):\n",
        "            if tuple(tokens[i:i+k]) == prefix:\n",
        "                next_tokens.append(tokens[i+k])\n",
        "\n",
        "    return next_tokens\n",
        "\n",
        "\n",
        "def smoothed_distribution(tokens, vocab, alpha=0.0):\n",
        "    \"\"\"\n",
        "    Distribución categórica sobre vocabulario con suavizado aditivo.\n",
        "    \"\"\"\n",
        "    counts = Counter(tokens)\n",
        "    values = np.array([counts[token] for token in vocab], dtype=float)\n",
        "    values = values + alpha\n",
        "\n",
        "    if values.sum() == 0:\n",
        "        raise ValueError(\"No hay masa de probabilidad para normalizar.\")\n",
        "\n",
        "    return values / values.sum()"
      ],
      "id": "074f628a",
      "execution_count": null,
      "outputs": []
    },
