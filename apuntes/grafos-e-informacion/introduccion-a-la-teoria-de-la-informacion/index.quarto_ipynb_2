      "source": [
        "def kl_discrete(p, q, base=2):\n",
        "    \"\"\"\n",
        "    Calcula D_KL(P || Q) para distribuciones discretas.\n",
        "\n",
        "    Parámetros:\n",
        "    -----------\n",
        "    p : Arreglo de Numpy que hace el papel de distribución de referencia P.\n",
        "    q : Arreglo de Numpy que hace el papel de distribución aproximante Q.\n",
        "    base : Base del logaritmo. Si base=2, la divergencia se mide en bits.\n",
        "    Si base=np.e, se mide en nats. Si base=10, se mide en bans.\n",
        "\n",
        "    Retorna:\n",
        "    --------\n",
        "    dkl : Divergencia de Kullback-Leibler D_KL(P || Q).\n",
        "    \"\"\"\n",
        "    p = np.asarray(p, dtype=float)\n",
        "    q = np.asarray(q, dtype=float)\n",
        "\n",
        "    if not np.isclose(p.sum(), 1.0):\n",
        "        raise ValueError(\"p debe sumar 1.\")\n",
        "\n",
        "    if not np.isclose(q.sum(), 1.0):\n",
        "        raise ValueError(\"q debe sumar 1.\")\n",
        "\n",
        "    if np.any((p > 0) & (q == 0)):\n",
        "        return np.inf\n",
        "\n",
        "    mask = p > 0\n",
        "\n",
        "    return np.sum(p[mask] * np.log(p[mask] / q[mask]) / np.log(base))"
      ],
