    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Reescalamiento de embeddings.\n",
        "a = 3.0\n",
        "X_mid = embeddings[\"Lenguaje intermedio\"]\n",
        "X_mid_scaled = a * X_mid\n",
        "\n",
        "cov_mid = np.cov(X_mid, rowvar=False)\n",
        "cov_mid_scaled = np.cov(X_mid_scaled, rowvar=False)\n",
        "\n",
        "h_mid = gaussian_differential_entropy(cov_mid, base=2)\n",
        "h_mid_scaled = gaussian_differential_entropy(cov_mid_scaled, base=2)\n",
        "\n",
        "scale_effect_df = pd.DataFrame({\n",
        "    \"Caso\": [\"Original\", \"Reescalado por a=3\"],\n",
        "    \"Entropía diferencial [bits]\": [h_mid, h_mid_scaled]\n",
        "})\n",
        "\n",
        "scale_effect_df"
