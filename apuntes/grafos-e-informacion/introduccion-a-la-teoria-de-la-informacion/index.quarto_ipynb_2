    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "def entropy_discrete(p, base=2):\n",
        "    \"\"\"\n",
        "    Calcula la entropía de Shannon de una distribución discreta.\n",
        "\n",
        "    Parámetros:\n",
        "    -----------\n",
        "    p : Vector de probabilidades.\n",
        "    base : Base del logaritmo. Si base=2, la entropía se mide en bits.\n",
        "    Si base=np.e, la entropía se mide en nats. Si base=10.0, la entropía\n",
        "    se mide en bans.\n",
        "\n",
        "    Retorna:\n",
        "    --------\n",
        "    H : Entropía de la distribución.\n",
        "    \"\"\"\n",
        "    p = np.asarray(p, dtype=float)\n",
        "\n",
        "    # Conservamos sólo probabilidades estrictamente positivas,\n",
        "    # usando la convención 0 log(0) = 0.\n",
        "    p = p[p > 0]\n",
        "\n",
        "    return -np.sum(p * np.log(p) / np.log(base))"
      ],
      "id": "50bd3c64",
      "execution_count": null,
      "outputs": []
