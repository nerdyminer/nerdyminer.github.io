        "        s=20,\n",
        "        color=\"firebrick\",\n",
        "        alpha=0.7\n",
        "    )\n",
        "\n",
        "    ax[j].set_xlabel(\n",
        "        fr\"$X_{j+1}$\",\n",
        "        fontsize=11,\n",
        "        labelpad=10\n",
