      "id": "e320d7a1",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-introduccion-a-la-teoria-de-la-informacion-09\n",
        "#| fig-cap: Visualización de las relaciones entre cada variable y la respuesta.\n",
        "# Visualización de las relaciones entre cada variable y la respuesta.\n",
        "fig, ax = plt.subplots(\n",
        "    nrows=1,\n",
        "    ncols=X.shape[1],\n",
        "    figsize=(9, 4),\n",
        "    sharey=True\n",
        ")\n",
        "\n",
        "for j in range(X.shape[1]):\n",
        "\n",
        "    ax[j].scatter(\n",
        "        X[:, j],\n",
