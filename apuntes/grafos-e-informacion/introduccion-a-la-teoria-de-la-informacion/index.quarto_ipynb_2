        "\n",
        "ax.set_xlabel(r\"Dimensión latente $z_1$\", fontsize=12, labelpad=10)\n",
        "ax.set_ylabel(r\"Dimensión latente $z_2$\", fontsize=12, labelpad=10)\n",
