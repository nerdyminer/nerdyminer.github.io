        "def softmax(scores):\n",
        "    \"\"\"\n",
        "    Calcula softmax de manera numéricamente estable.\n",
        "    \"\"\"\n",
        "    scores = np.asarray(scores, dtype=float)\n",
        "    c = np.max(scores)\n",
        "    exp_scores = np.exp(scores - c)\n",
        "    return exp_scores / exp_scores.sum()\n",
        "\n",
        "\n",
        "def maxent_distribution(lam, F):\n",
        "    \"\"\"\n",
        "    Distribución de máxima entropía inducida por los multiplicadores lam.\n",
        "\n",
        "    q_lam(t) ∝ exp(lam^T phi(t)).\n",
        "    \"\"\"\n",
        "    scores = F @ lam\n",
        "    return softmax(scores)\n",
        "\n",
        "\n",
        "def maxent_dual_objective(lam, F, alpha):\n",
        "    \"\"\"\n",
        "    Objetivo dual convexo del problema de máxima entropía:\n",
        "\n",
        "        A(lam) - lam^T alpha,\n",
        "\n",
        "    donde A(lam)=log(sum_t exp(lam^T phi(t))).\n",
        "    \"\"\"\n",
        "    scores = F @ lam\n",
        "    c = np.max(scores)\n",
        "\n",
        "    log_partition = c + np.log(np.sum(np.exp(scores - c)))\n",
        "\n",
        "    return log_partition - lam @ alpha\n",
        "\n",
        "\n",
        "def maxent_dual_gradient(lam, F, alpha):\n",
        "    \"\"\"\n",
        "    Gradiente del objetivo dual:\n",
        "\n",
        "        E_q[phi(T)] - alpha.\n",
        "    \"\"\"\n",
        "    q = maxent_distribution(lam, F)\n",
        "    expected_features = F.T @ q\n",
        "\n",
        "    return expected_features - alpha"
      ],
