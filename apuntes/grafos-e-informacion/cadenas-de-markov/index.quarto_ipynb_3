      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Estados operacionales.\n",
        "states = [\"Normal\", \"Alerta\", \"Restricción\", \"Detención\"]\n",
        "\n",
        "# Matriz de transición.\n",
        "P = np.array([\n",
        "    [0.82, 0.14, 0.03, 0.01],  # Normal\n",
        "    [0.35, 0.40, 0.20, 0.05],  # Alerta\n",
        "    [0.18, 0.22, 0.45, 0.15],  # Restricción\n",
        "    [0.55, 0.20, 0.10, 0.15],  # Detención\n",
        "])\n",
        "\n",
        "# Verificación de que cada fila suma 1.\n",
        "P.sum(axis=1)"
      ],
      "id": "a66054b2",
      "execution_count": null,
      "outputs": []
